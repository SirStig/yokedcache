    <div class="used-strip">
      <a href="https://www.projectyoked.com" target="_blank" rel="noopener">
        <img class="used-strip-logo" src="https://projectyoked.com/assets/project-yoked-logo.png" alt="Project Yoked" width="112" height="28">
